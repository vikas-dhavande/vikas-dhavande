# ─── Appwrite Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=your_database_id_here
VITE_APPWRITE_CONTACTS_COLLECTION_ID=your_contacts_collection_id_here
VITE_APPWRITE_PROJECTS_COLLECTION_ID=your_projects_collection_id_here
VITE_APPWRITE_BLOGS_COLLECTION_ID=your_blogs_collection_id_here
